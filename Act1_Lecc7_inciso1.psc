Algoritmo  Act1_Lecc7_inciso1
	Definir n1,n2,n3,n4,n5,prom Como Real
	
	Escribir "Luis Priego-IV-E"
	Escribir "Ingrese 5 calificaciones:"
	Leer n1,n2,n3,n4,n5
	
	prom = (n1+n2+n3+n4+n5) / 5
	
	Si prom >= 70 Entonces
		Escribir "Aprueba"
	SiNo
		Escribir "Reprueba"
	FinSi
FinAlgoritmo
